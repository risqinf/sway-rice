{
    "layer": "top",
    "position": "top",
    "height": 38,
    "spacing": 6,
    "margin-top": 6,
    "margin-bottom": 4,
    "margin-left": 10,
    "margin-right": 10,
    "modules-left": [
        "sway/workspaces"
    ],
    "modules-center": [
        "custom/cava"
    ],
    "modules-right": [
        "custom/recorder",
        "custom/audio-system",
        "custom/uptime",
        "custom/power",
        "network",
        "cpu",
        "memory",
        "temperature",
        "backlight",
        "pulseaudio",
        "battery",
        "clock"
    ],
    "sway/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "format": "{name}"
    },
    "custom/cava": {
        "exec": "bash ~/.config/sway/cava.sh 2>/dev/null || echo ''",
        "exec-if": "command -v cava >/dev/null 2>&1",
        "format": "{}"
    },
    "custom/uptime": {
        "exec": "awk '{print int($1/3600)\"h \"int(($1%3600)/60)\"m\"}' /proc/uptime",
        "interval": 60,
        "format": "  {}"
    },
    "custom/power": {
        "exec": "P=$(tuned-adm active 2>/dev/null | awk -F': ' '{print $2}'); [[ \"$P\" == *\"performance\"* ]] && echo '  Perf' || [[ \"$P\" == *\"powersave\"* ]] && echo '  Save' || echo '  Bal'",
        "interval": 5,
        "format": "{}"
    },
    "clock": {
        "format": "  {:%H:%M    %d %b %Y}",
        "tooltip-format": "<big>{:%Y %B}</big>\\n<tt><small>{calendar}</small></tt>"
    },
    "network": {
        "interval": 2,
        "format-wifi": "  {essid}    {bandwidthDownBits}    {bandwidthUpBits}",
        "format-ethernet": "  {ipaddr}    {bandwidthDownBits}    {bandwidthUpBits}",
        "format-disconnected": "  Offline",
        "on-click": "~/.local/bin/kitty -e nmtui"
    },
    "cpu": {
        "interval": 2,
        "format": "  {usage}%",
        "on-click": "~/.local/bin/kitty -e htop"
    },
    "memory": {
        "interval": 2,
        "format": "  {used:0.1f}GB",
        "on-click": "~/.local/bin/kitty -e top -o %MEM"
    },
    "temperature": {
        "critical-threshold": 80,
        "format": "  {temperatureC}°C"
    },
    "backlight": {
        "device": "amdgpu_bl1",
        "format": "  {percent}%",
        "on-scroll-up": "bash ~/.config/sway/brightness.sh up",
        "on-scroll-down": "bash ~/.config/sway/brightness.sh down"
    },
    "pulseaudio": {
        "format": "  {volume}%",
        "format-muted": "  Muted",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 2%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%-"
    },
    "custom/recorder": {
        "exec": "PID=$(cat /tmp/waybar-recorder.pid 2>/dev/null); [[ -n \"$PID\" ]] && kill -0 \"$PID\" 2>/dev/null && echo '  REC' || echo ''",
        "interval": 1,
        "format": "{}",
        "on-click": "bash ~/.config/sway/gui-recorder.sh",
        "on-click-right": "bash -c 'PID=$(cat /tmp/waybar-recorder.pid 2>/dev/null); [[ -n \"$PID\" ]] && kill -s SIGINT \"$PID\" 2>/dev/null; rm -f /tmp/waybar-recorder.pid; notify-send \"Recorder\" \"Stopped\" 2>/dev/null || true'",
        "exec-if": "test -f /tmp/waybar-recorder.pid && kill -0 $(cat /tmp/waybar-recorder.pid) 2>/dev/null"
    },
    "custom/audio-system": {
        "exec": "PID=$(cat /tmp/waybar-audio-system.pid 2>/dev/null); [[ -n \"$PID\" ]] && kill -0 \"$PID\" 2>/dev/null && echo '  SYS' || echo ''",
        "interval": 1,
        "format": "{}",
        "on-click": "bash ~/.config/sway/gui-recorder.sh",
        "on-click-right": "bash -c 'PID=$(cat /tmp/waybar-audio-system.pid 2>/dev/null); [[ -n \"$PID\" ]] && kill -s SIGINT \"$PID\" 2>/dev/null; rm -f /tmp/waybar-audio-system.pid; notify-send \"Audio System\" \"Stopped\" 2>/dev/null || true'",
        "exec-if": "test -f /tmp/waybar-audio-system.pid && kill -0 $(cat /tmp/waybar-audio-system.pid) 2>/dev/null"
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "  {capacity}%",
        "format-plugged": "  {capacity}%",
        "format-icons": [
            "",
            "",
            "",
            "",
            ""
        ]
    }
}
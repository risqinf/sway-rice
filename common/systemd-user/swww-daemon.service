[Unit]
Description=swww wallpaper daemon
PartOf=graphical-session.target
After=graphical-session.target
# Tanpa ConditionEnvironment=WAYLAND_DISPLAY — lihat waybar.service.

[Service]
Type=simple
ExecStart=%h/.cargo/bin/swww-daemon
Restart=on-failure
RestartSec=1
# Matikan cepat saat session turun — jangan biarkan jadi orphan yang
# menahan shutdown/reboot.
TimeoutStopSec=3
KillMode=mixed
KillSignal=SIGTERM

[Install]
WantedBy=graphical-session.target
